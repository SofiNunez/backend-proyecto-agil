generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Notification {
  id                String   @id @default(uuid())
  notificationId    String   @unique
  channel           String
  provider          String
  providerMessageId String?
  recipient         String
  attempts          Int
  status            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  statusHistory     Json
}